# Base URL of the API including /api path, no trailing slash.
# Build-time for Vite; must match CORS on the server for your UI origin.
# Локальная разработка с Vite proxy (рекомендуется):
VITE_API_BASE_URL=/api

# Прямой доступ к API без proxy:
# VITE_API_BASE_URL=http://localhost:8080/api

# Опционально, если картинки каталога с другого origin:
# VITE_API_ORIGIN=http://localhost:8080
