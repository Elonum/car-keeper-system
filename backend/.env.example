# Copy to .env and adjust. Never commit real secrets.

# --- Runtime ---
ENV=development
# production: enables stricter checks (e.g. JWT_SECRET must not be default)

# --- HTTP ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# Max JSON body (non-multipart), bytes
MAX_JSON_BODY_BYTES=1048576

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=carkeeper
DB_SSLMODE=disable

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24

# --- Documents on disk (metadata in DB) ---
DOCUMENT_STORAGE_ROOT=./data/documents
DOCUMENT_MAX_UPLOAD_BYTES=15728640

# --- CORS (comma-separated origins, no spaces). Required in production if UI is on another origin. ---
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
