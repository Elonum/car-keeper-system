# Copy to .env and adjust. Never commit real secrets.

ENV=development

# PostgreSQL (DSN-style; used by pgx)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=carkeeper
DB_SSLMODE=disable

# HTTP (use 0.0.0.0 in containers)
SERVER_HOST=localhost
SERVER_PORT=8080

# Auth — set a long random string in production; config rejects default when ENV=production
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24

# Comma-separated browser origins for CORS (omit for localhost dev defaults)
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
